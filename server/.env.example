# Server environment variables
PORT=8000
MONGODB_URL=mongodb+srv://<username>:<password>@cluster0.mongodb.net/mydatabase?retryWrites=true&w=majority
JWT_SECRET=your_jwt_secret_here
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
OPENROUTER_API_KEY=your_openrouter_api_key
ALLOWED_ORIGINS=http://localhost:5173,https://ai-interview-shubh.vercel.app,https://mockverse.online,https://www.mockverse.online
# Optional: set when your server and client are on custom domains
COOKIE_DOMAIN=.your-domain.com
NODE_ENV=development
